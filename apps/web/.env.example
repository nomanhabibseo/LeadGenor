# Copy to `.env.local` for local dev, or set equivalent keys on Vercel (Production).
# Canonical site URL — must match the URL users open in the browser (www vs apex).
NEXTAUTH_URL="http://localhost:3000"

# openssl rand -hex 32 — long random secret; rotate if exposed.
NEXTAUTH_SECRET=""

# Render / API base (same for browser + server-side Next in production).
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_URL="http://localhost:4000"
