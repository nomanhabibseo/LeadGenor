# Local Postgres: set both (same URI). Required by Prisma `directUrl`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadgenor?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/leadgenor?schema=public"
# `packages/db` postinstall skips `prisma generate` when either var is unset (Vercel web-only installs).
#
# Supabase + Prisma: transaction pool `@…pooler…:6543?pgbouncer=true` for runtime; SESSION pool SAME host `:5432` for migrate (`prepared statement` errors on :6543).
# Use connection_limit >= 5 for Nest (HTTP + imports). `connection_limit=1` causes P2024 pool timeouts, JWT failures, and blank lists/templates pages.
# DATABASE_URL="postgresql://postgres.[ref]:…@aws-….pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=30"
# DIRECT_URL="postgresql://postgres.[ref]:…@aws-….pooler.supabase.com:5432/postgres"
# Optional: campaign send poll (ms). Dev defaults to 15s if unset; prod defaults to 1s.
# CAMPAIGN_SEND_TICK_MS=15000
# Required for campaigns to actually send mail during `npm run dev` / `npm run start:dev`. Without it, status shows RUNNING but SENT stays 0.
# If Prisma pool errors (Supabase connection_limit=1), omit this or set 0 and use a higher DB connection_limit instead.
ENABLE_EMAIL_SCHEDULERS_IN_DEV=1
# API listen port (Nest). Must match API_URL / NEXT_PUBLIC_API_URL.
PORT=4000
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Dev: set to 1 so the browser talks to the API URL directly instead of the Next.js rewrite (helps avoid proxy disconnects on long Google Sheet imports).
# NEXT_PUBLIC_DEV_USE_DIRECT_API=1
JWT_SECRET="change-me-shared-with-api"

# Comma-separated emails allowed to access admin activation endpoints.
# Example: ADMIN_EMAILS="nomanhabib.seo@gmail.com,other@domain.com"
ADMIN_EMAILS="nomanhabib.seo@gmail.com"

# --- Email marketing (Nest API) ---
# Same secret in API + web for encrypting SMTP/OAuth tokens at rest (min ~32 chars recommended).
ENCRYPTION_KEY="change-me-long-random-string-for-email-secrets"
# Public URL of the API (used in unsubscribe + open tracking links in outgoing mail).
API_PUBLIC_URL="http://localhost:4000"
# Site origin the API trusts for redirects / CORS (browser app URL).
WEB_ORIGIN="http://localhost:3000"

# Deploy: apply migrations once per schema change (`DATABASE_URL` must point at prod DB).
# npm run db:migrate:deploy
# Production (Render API): apex + www if both resolve to your app — required for browser → API cookies/CORS:
# WEB_ORIGIN="https://leadgenor.com"
# WEB_ORIGINS="https://www.leadgenor.com"
# Google Cloud OAuth (Gmail send + mailbox read)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/email-marketing/oauth/google/callback"
# Azure App registration (Outlook send + mailbox read)
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_REDIRECT_URI="http://localhost:4000/email-marketing/oauth/microsoft/callback"
# Optional; default "common" for multi-tenant consumer + work accounts
MICROSOFT_OAUTH_TENANT="common"
