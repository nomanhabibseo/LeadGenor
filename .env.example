DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadgenor?schema=public"
# API listen port (Nest). Must match API_URL / NEXT_PUBLIC_API_URL.
PORT=4000
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
JWT_SECRET="change-me-shared-with-api"

# --- Email marketing (Nest API) ---
# Same secret in API + web for encrypting SMTP/OAuth tokens at rest (min ~32 chars recommended).
ENCRYPTION_KEY="change-me-long-random-string-for-email-secrets"
# Public URL of the API (used in unsubscribe + open tracking links in outgoing mail).
API_PUBLIC_URL="http://localhost:4000"
# Where Google/Microsoft OAuth redirects after login (must be API routes, not Next.js).
WEB_ORIGIN="http://localhost:3000"
# Google Cloud OAuth (Gmail send + mailbox read)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/email-marketing/oauth/google/callback"
# Azure App registration (Outlook send + mailbox read)
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_REDIRECT_URI="http://localhost:4000/email-marketing/oauth/microsoft/callback"
# Optional; default "common" for multi-tenant consumer + work accounts
MICROSOFT_OAUTH_TENANT="common"
